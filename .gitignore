scripts/07_features.py
scripts/28_prepare_inter_annotation.py
scripts/28_prepare_inter_annotation_v2.py
scripts/32_compute_inter_kappa_fixed.py
scripts/34_mcnemars_test_with_hmm.py
scripts/35_mcnemars_test_dual_level.py

# Digantikan versi v2
scripts/14_train_hybrid_crf.py

# Debug & inspeksi (tidak untuk produksi)
scripts/debug_crf.py
scripts/debug_crf_v2.py
scripts/debug_hmm.py
scripts/debug_hmm_prediction.py
scripts/check_annotations.py
scripts/check_annotations_v2.py
scripts/check_hmm_structure.py
scripts/05_inspect.py
scripts/06_test_env.py
scripts/test_install.py

# Tidak terpakai
scripts/16_nergrit_loader.py
scripts/24_kappa_annotator.py
scripts/30_annotator_novi.py
scripts/patch_features_v2.py
scripts/patch_generator.py
