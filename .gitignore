# ============================================
# NDLP-Hybrid .gitignore
# ============================================

# Virtual Environment
venv/
.venv/
env/

# Dataset (di-generate ulang dengan scripts)
data/

# Model hasil training (bisa di-train ulang)
models/

# GNS3 VM files (sangat besar)
A. GNS3/

# Tools binary
tools/

# Hasil evaluasi & anotasi pribadi
evaluation/
annotation_package_novi/
Kirim Novi/

# Backup
backup_old/
backup_v1/

# Log files
logs/
*.log

# Cache Python
__pycache__/
*.pyc
*.pyo

# File besar
*.pkl
*.vdi
*.sav
*.tar.gz
*.tgz
*.zip
*.exe
*.dll

# OS & IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

# ============================================
# SCRIPTS YANG DIKECUALIKAN
# (duplikat, debug, tidak terpakai)
# ============================================

